# ═══════════════════════════════════════════════════════════════
#  MOLTY ROYALE AGENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# ─── Account Configuration ─────────────────────────────────────
# Leave API_KEY empty to create a new account automatically
API_KEY=
AGENT_NAME=JavaScriptBot

# ─── Wallet Configuration (Required for rewards) ───────────────
# Your Ethereum wallet address (0x + 40 hex characters)
# Required to receive Moltz rewards (even in free rooms)
WALLET_ADDRESS=

# ─── Game Configuration ────────────────────────────────────────
# Leave empty to auto-find/create game
GAME_ID=
AGENT_ID=

# ─── Team Configuration ────────────────────────────────────────
# Comma-separated list of ally agent names (for team mode)
# Leave empty to use default allies
ALLY_NAMES=

# ─── Aggression Mode ───────────────────────────────────────────
# Options: safe, balanced, brutal
# - safe: Conservative play, heal early, avoid risky fights
# - balanced: Standard play, balanced offense/defense
# - brutal: Aggressive play, fight more often, riskier trades
AGGRO_MODE=balanced

# ─── Ranged Targeting Mode ─────────────────────────────────────
# Options: adjacent, same_region
# - adjacent: Allow attacking connected regions with ranged weapons
# - same_region: Only attack same region (safer, more conservative)
RANGED_TARGET_MODE=adjacent

# ─── Advanced Configuration ────────────────────────────────────
# Allow creating new game if no waiting game exists (true/false)
ALLOW_CREATE_GAME_FALLBACK=false

# ─── Timeout Configuration (seconds) ───────────────────────────
API_CONNECT_TIMEOUT=3
API_READ_TIMEOUT=6
STATE_CONNECT_TIMEOUT=2
STATE_READ_TIMEOUT=4
ACTION_POST_CONNECT_TIMEOUT=3
ACTION_POST_READ_TIMEOUT=8
ACTION_CONFIRM_CONNECT_TIMEOUT=2.5
ACTION_CONFIRM_READ_TIMEOUT=3.5
CDN_CONNECT_TIMEOUT=3
CDN_READ_TIMEOUT=4

# ─── Retry Configuration ───────────────────────────────────────
API_DEFAULT_RETRIES=1
API_STATE_RETRIES=1
ACTION_POST_RETRIES=2
QUICK_RETRY_BACKOFF=0.25

# ─── Delay Configuration (seconds) ─────────────────────────────
PICKUP_SUCCESS_DELAY=0.35
PICKUP_FAIL_DELAY=0.50
PICKUP_MULTI_SUCCESS_DELAY=0.18
PICKUP_MULTI_FAIL_DELAY=0.30
GROUP1_COOLDOWN_POLL_DELAY=0.45
IDLE_NO_ACTION_DELAY=1.25

# ─── Dashboard Configuration ───────────────────────────────────
# Port for web dashboard
DASHBOARD_PORT=3000
# Directory for agent .env files (relative to script location)
AGENTS_DIR=agents
